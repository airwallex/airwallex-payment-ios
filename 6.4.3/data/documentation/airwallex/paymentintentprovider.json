{"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["swift"],"tokens":[{"text":"@objc","kind":"attribute"},{"text":" ","kind":"text"},{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PaymentIntentProvider","kind":"identifier"}]}],"kind":"declarations"},{"content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"PaymentIntentProvider"},{"type":"text","text":" enables delayed payment intent creation, allowing you to defer"},{"type":"text","text":" "},{"type":"text","text":"the creation of a payment intent until just before payment confirmation or when it is required."}]},{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When using "},{"type":"codeVoice","code":"Session"},{"type":"text","text":" with a payment intent provider instead of a pre-created intent,"},{"type":"text","text":" "},{"type":"text","text":"the SDK will call "},{"type":"codeVoice","code":"createPaymentIntent()"},{"type":"text","text":" asynchronously when needed. The provider"},{"type":"text","text":" "},{"type":"text","text":"must also supply the basic payment information (amount, currency, customerId) synchronously."}]},{"text":"Usage Example","type":"heading","level":2,"anchor":"Usage-Example"},{"type":"codeListing","syntax":"swift","code":["class MyPaymentIntentProvider: NSObject, PaymentIntentProvider {","    let amount: NSDecimalNumber = NSDecimalNumber(string: \"99.99\")","    let currency: String = \"USD\"","    let customerId: String? = \"customer_123\"","","    func createPaymentIntent() async throws -> AWXPaymentIntent {","        \/\/ Call your backend to create the payment intent","        let response = try await MyBackendAPI.createPaymentIntent(","            amount: amount.decimalValue,","            currency: currency,","            customerId: customerId","        )","        return response.paymentIntent","    }","}","","\/\/ Use with Session","let provider = MyPaymentIntentProvider()","let session = Session(","    paymentIntentProvider: provider,","    countryCode: \"US\",","    returnURL: \"myapp:\/\/payment\/return\"",")"]},{"text":"Important Notes","type":"heading","level":2,"anchor":"Important-Notes"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"The "},{"code":"amount","type":"codeVoice"},{"type":"text","text":", "},{"code":"currency","type":"codeVoice"},{"type":"text","text":" and "},{"code":"customerId","type":"codeVoice"},{"type":"text","text":" properties must return values immediately (they cannot be async)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The values returned by "},{"code":"amount","type":"codeVoice"},{"type":"text","text":", "},{"code":"currency","type":"codeVoice"},{"type":"text","text":" and "},{"code":"customerId","type":"codeVoice"},{"type":"text","text":" must match the values"},{"type":"text","text":" "},{"type":"text","text":"in the "},{"code":"AWXPaymentIntent","type":"codeVoice"},{"type":"text","text":" returned by "},{"code":"createPaymentIntent()","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The "},{"code":"amount","type":"codeVoice"},{"type":"text","text":" should be zero for recurring-only payments (no immediate charge)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The "},{"code":"createPaymentIntent()","type":"codeVoice"},{"type":"text","text":" method will only be called once, and the result is cached"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"If "},{"code":"createPaymentIntent()","type":"codeVoice"},{"type":"text","text":" throws an error, the payment flow will fail"}],"type":"paragraph"}]}]},{"type":"aside","style":"note","name":"See Also","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"code":"Session","type":"codeVoice"},{"type":"text","text":", "},{"code":"AWXPaymentIntent","type":"codeVoice"}]}]}],"kind":"content"}],"abstract":[{"text":"A protocol for providing payment intents on-demand during the payment flow.","type":"text"}],"topicSections":[{"generated":true,"identifiers":["doc:\/\/org.cocoapods.Airwallex\/documentation\/Airwallex\/PaymentIntentProvider\/amount","doc:\/\/org.cocoapods.Airwallex\/documentation\/Airwallex\/PaymentIntentProvider\/currency","doc:\/\/org.cocoapods.Airwallex\/documentation\/Airwallex\/PaymentIntentProvider\/customerId"],"anchor":"Instance-Properties","title":"Instance Properties"},{"generated":true,"identifiers":["doc:\/\/org.cocoapods.Airwallex\/documentation\/Airwallex\/PaymentIntentProvider\/createPaymentIntent()"],"anchor":"Instance-Methods","title":"Instance Methods"}],"metadata":{"externalID":"c:@M@Airwallex@objc(pl)PaymentIntentProvider","role":"symbol","modules":[{"name":"Airwallex"}],"symbolKind":"protocol","title":"PaymentIntentProvider","navigatorTitle":[{"text":"PaymentIntentProvider","kind":"identifier"}],"roleHeading":"Protocol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PaymentIntentProvider","kind":"identifier"}]},"hierarchy":{"paths":[["doc:\/\/org.cocoapods.Airwallex\/documentation\/Airwallex"]]},"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/org.cocoapods.Airwallex\/documentation\/Airwallex\/PaymentIntentProvider"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/airwallex\/paymentintentprovider"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/airwallex\/paymentintentprovider"]}],"references":{"doc://org.cocoapods.Airwallex/documentation/Airwallex/PaymentIntentProvider/createPaymentIntent()":{"title":"createPaymentIntent()","type":"topic","role":"symbol","navigatorTitle":[{"text":"- "