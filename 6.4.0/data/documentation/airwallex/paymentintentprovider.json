confirmation or when it is required.","type":"text"}],"type":"paragraph"},{"text":"Overview","anchor":"Overview","type":"heading","level":2},{"inlineContent":[{"text":"When using ","type":"text"},{"type":"codeVoice","code":"Session"},{"text":" with a payment intent provider instead of a pre-created intent,","type":"text"},{"text":" ","type":"text"},{"text":"the SDK will call ","type":"text"},{"type":"codeVoice","code":"createPaymentIntent()"},{"text":" asynchronously when needed. The provider","type":"text"},{"text":" ","type":"text"},{"text":"must also supply the basic payment information (amount, currency, customerId) synchronously.","type":"text"}],"type":"paragraph"},{"anchor":"Usage-Example","type":"heading","level":2,"text":"Usage Example"},{"type":"codeListing","code":["class MyPaymentIntentProvider: NSObject, PaymentIntentProvider {","    let amount: NSDecimalNumber = NSDecimalNumber(string: \"99.99\")","    let currency: String = \"USD\"","    let customerId: String? = \"customer_123\"","","    func createPaymentIntent() async throws -> AWXPaymentIntent {","        \/\/ Call your backend to create the payment intent","        let response = try await MyBackendAPI.createPaymentIntent(","            amount: amount.decimalValue,","            currency: currency,","            customerId: customerId","        )","        return response.paymentIntent","    }","}","","\/\/ Use with Session","let provider = MyPaymentIntentProvider()","let session = Session(","    paymentIntentProvider: provider,","    countryCode: \"US\",","    returnURL: \"myapp:\/\/payment\/return\"",")"],"syntax":"swift"},{"anchor":"Important-Notes","type":"heading","level":2,"text":"Important Notes"},{"items":[{"content":[{"inlineContent":[{"text":"The ","type":"text"},{"code":"amount","type":"codeVoice"},{"text":", ","type":"text"},{"code":"currency","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"customerId","type":"codeVoice"},{"text":" properties must return values immediately (they cannot be async)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The values returned by ","type":"text"},{"type":"codeVoice","code":"amount"},{"text":", ","type":"text"},{"type":"codeVoice","code":"currency"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"customerId"},{"text":" must match the values","type":"text"},{"text":" ","type":"text"},{"text":"in the ","type":"text"},{"type":"codeVoice","code":"AWXPaymentIntent"},{"text":" returned by ","type":"text"},{"type":"codeVoice","code":"createPaymentIntent()"}]}]},{"content":[{"inlineContent":[{"text":"The ","type":"text"},{"code":"amount","type":"codeVoice"},{"text":" should be zero for recurring-only payments (no immediate charge)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"createPaymentIntent()"},{"type":"text","text":" method will only be called once, and the result is cached"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"createPaymentIntent()"},{"type":"text","text":" throws an error, the payment flow will fail"}]}]}],"type":"unorderedList"},{"name":"See Also","content":[{"inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"Session"},{"type":"text","text":", "},{"type":"codeVoice","code":"AWXPaymentIntent"}],"type":"paragraph"}],"style":"note","type":"aside"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.cocoapods.Airwallex\/documentation\/Airwallex"]]},"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"text","text":"A protocol for providing payment intents on-demand during the payment flow."}],"references":{"doc://org.cocoapods.Airwallex/documentation/Airwallex/PaymentIntentProvider/customerId":{"url":"\/documentation\/airwallex\/paymentintentprovider\/customerid","abstract":[{"text":"The customer ID associated with this 