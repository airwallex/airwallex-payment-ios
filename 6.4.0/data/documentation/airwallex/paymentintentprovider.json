{"hierarchy":{"paths":[["doc:\/\/org.cocoapods.Airwallex\/documentation\/Airwallex"]]},"sections":[],"metadata":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PaymentIntentProvider","kind":"identifier"}],"externalID":"c:@M@Airwallex@objc(pl)PaymentIntentProvider","navigatorTitle":[{"text":"PaymentIntentProvider","kind":"identifier"}],"role":"symbol","title":"PaymentIntentProvider","modules":[{"name":"Airwallex"}],"roleHeading":"Protocol","symbolKind":"protocol"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/org.cocoapods.Airwallex\/documentation\/Airwallex\/PaymentIntentProvider"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@objc","kind":"attribute"},{"text":" ","kind":"text"},{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PaymentIntentProvider","kind":"identifier"}],"platforms":["iOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"inlineContent":[{"type":"codeVoice","code":"PaymentIntentProvider"},{"type":"text","text":" enables delayed payment intent creation, allowing you to defer"},{"type":"text","text":" "},{"type":"text","text":"the creation of a payment intent until just before payment confirmation or when it is required."}],"type":"paragraph"},{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"When using "},{"type":"codeVoice","code":"Session"},{"text":" with a payment intent provider instead of a pre-created intent,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the SDK will call "},{"type":"codeVoice","code":"createPaymentIntent()"},{"type":"text","text":" asynchronously when needed. The provider"},{"type":"text","text":" "},{"type":"text","text":"must also supply the basic payment information (amount, currency, customerId) synchronously."}],"type":"paragraph"},{"text":"Usage Example","level":2,"type":"heading","anchor":"Usage-Example"},{"syntax":"swift","type":"codeListing","code":["class MyPaymentIntentProvider: NSObject, PaymentIntentProvider {","    let amount: NSDecimalNumber = NSDecimalNumber(string: \"99.99\")","    let currency: String = \"USD\"","    let customerId: String? = \"customer_123\"","","    func createPaymentIntent() async throws -> AWXPaymentIntent {","        \/\/ Call your backend to create the payment intent","        let response = try await MyBackendAPI.createPaymentIntent(","            amount: amount.decimalValue,","            currency: currency,","            customerId: customerId","        )","        return response.paymentIntent","    }","}","","\/\/ Use with Session","let provider = MyPaymentIntentProvider()","let session = Session(","    paymentIntentProvider: provider,","    countryCode: \"US\",","    returnURL: \"myapp:\/\/payment\/return\"",")"]},{"level":2,"text":"Important Notes","anchor":"Important-Notes","type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"amount"},{"type":"text","text":", "},{"type":"codeVoice","code":"currency"},{"type":"text","text":" and "},{"type":"codeVoice","code":"customerId"},{"text":" properties must return values immediately (they cannot be async)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"The values returned by ","type":"text"},{"code":"amount","type":"codeVoice"},{"text":", ","type":"text"},{"code":"currency","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"customerId"},{"type":"text","text":" must match the values"},{"type":"text","text":" "},{"type":"text","text":"in the "},{"code":"AWXPaymentIntent","type":"codeVoice"},{"text":" returned by ","type":"text"},{"code":"createPaymentIntent()","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"amount"},{"type":"text","text":" should be zero for recurring-only payments (no immediate charge)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"createPaymentIntent()"},{"text":" method will only be called once, and the result is cached","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"createPaymentIntent()"},{"text":" throws an error, the payment flow will fail","type":"text"}]}]}],"type":"unorderedList"},{"content":[{"inlineContent":[{"text":"","type":"text"},{"code":"Session","type":"codeVoice"},{"text":", ","type":"text"},{"code":"AWXPaymentIntent","type":"codeVoice"}],"type":"paragraph"}],"type":"aside","style":"note","name":"See Also"}],"kind":"content"}],"abstract":[{"text":"A protocol for providing payment intents on-demand during the payment flow.","type":"text"}],"topicSections":[{"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/org.cocoapods.Airwallex\/documentation\/Airwallex\/PaymentIntentProvider\/amount","doc:\/\/org.cocoapods.Airwallex\/documentation\/Airwallex\/PaymentIntentProvider\/currency","doc:\/\/org.cocoapods.Airwallex\/documentation\/Airwallex\/PaymentIntentProvider\/customerId"],"generated":true},{"identifiers":["doc:\/\/org.cocoapods.Airwallex\/documentation\/Airwallex\/PaymentIntentProvider\/createPaymentIntent()"],"generated":true,"title":"Instance Methods","anchor":"Instance-Methods"}],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/airwallex\/paymentintentprovider"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/airwallex\/paymentintentprovider"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://org.cocoapods.Airwallex/documentation/Airwallex":{"type":"topic","url":"\/documentation\/airwallex","identifier":"doc:\/\/org.cocoapods.Airwallex\/documentation\/Airwallex","title":"Airwallex","kind":"symbol","r