#!/bin/bash

# SwiftLint pre-commit hook
# Blocks commit if SwiftLint finds any warnings or errors

if test -d "/opt/homebrew/bin/"; then
  PATH="/opt/homebrew/bin/:${PATH}"
fi

export PATH

if ! which swiftlint >/dev/null; then
  echo "warning: SwiftLint not installed, skipping pre-commit check"
  exit 0
fi

# Run SwiftLint with --strict to treat warnings as errors
# Only lint staged Swift files for faster commits
STAGED_SWIFT_FILES=$(git diff --cached --name-only --diff-filter=d | grep "\.swift$")

if [ -z "$STAGED_SWIFT_FILES" ]; then
  exit 0  # No Swift files staged
fi

echo "Running SwiftLint on staged files..."

# Lint only staged files
echo "$STAGED_SWIFT_FILES" | xargs swiftlint lint --strict --quiet

if [ $? -ne 0 ]; then
  echo ""
  echo "SwiftLint found violations. Attempting auto-fix..."

  # Try to auto-fix the issues
  echo "$STAGED_SWIFT_FILES" | xargs swiftlint --fix --quiet

  # Re-stage the fixed files
  echo "$STAGED_SWIFT_FILES" | xargs git add

  # Retry lint
  echo "Retrying SwiftLint after auto-fix..."
  echo "$STAGED_SWIFT_FILES" | xargs swiftlint lint --strict --quiet

  if [ $? -ne 0 ]; then
    echo ""
    echo "SwiftLint still found violations after auto-fix. Please fix them manually before committing."
    exit 1
  fi

  echo "SwiftLint auto-fix succeeded. Files have been re-staged."
fi

echo "SwiftLint passed"
exit 0
